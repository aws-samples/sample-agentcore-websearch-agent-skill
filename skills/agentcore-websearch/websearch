#!/usr/bin/env bash
# Convenience wrapper around the packaged CLI. The supported entry point is the
# `agentcore-websearch` console command installed via `pip install .` (or pipx);
# this wrapper just runs it from the bundle's own venv so `./websearch ...` works
# without activating anything. It also loads this folder's .env automatically (the
# Python CLI does that itself, too).
#
#   pip install .            # then:  agentcore-websearch "query"
#   ./websearch "query"      # equivalent, via the bundle venv
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PY="$HERE/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"

# Prefer the installed console script if present; else run the module directly.
if [ -x "$HERE/.venv/bin/agentcore-websearch" ]; then
  exec "$HERE/.venv/bin/agentcore-websearch" "$@"
fi
exec "$PY" -m agentcore_websearch.cli "$@"
